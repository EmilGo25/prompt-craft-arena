# Copy to .env and fill in. The stub provider/judge need no keys at all.

# Image generation: "stub" (no key, offline) | "fal"
IMAGE_PROVIDER=stub
FAL_KEY=

# Judge: "random" (no key, offline) | "claude"
JUDGE=random
ANTHROPIC_API_KEY=

# Gameplay
ROUND_SECONDS=30
TOTAL_ROUNDS=5
MAX_RESULT_CONCURRENCY=4
