# Copy to .env and fill in. The stub provider/judge need no keys at all.

# OpenAI powers both image generation and the LLM judge.
OPENAI_API_KEY=

# Image generation: "stub" (no key, offline) | "openai" | "drawthings" (local)
IMAGE_PROVIDER=stub
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024
# Local, open-weight image gen (FLUX.1 / SDXL) via Draw Things or any
# A1111-compatible WebUI. Load the model in that app; we just send prompts.
DRAWTHINGS_API_BASE=http://localhost:7860
DRAWTHINGS_STEPS=4
DRAWTHINGS_SIZE=1024x1024

# Judge: "random" (no key, offline) | "openai" | "ollama" (local)
JUDGE=random
JUDGE_MODEL=gpt-4o
# Local, open-weight vision judge via Ollama's OpenAI-compatible endpoint.
# Pull a model first, e.g.: ollama pull qwen2.5vl:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_JUDGE_MODEL=qwen2.5vl:7b

# Gameplay
ROUND_SECONDS=60
TOTAL_ROUNDS=5
MAX_RESULT_CONCURRENCY=4
# Target difficulty: easy | medium | hard | ramp (ramp = easy -> hard across rounds)
TARGET_DIFFICULTY=medium
